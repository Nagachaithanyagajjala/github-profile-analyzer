# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Naga@1212
DB_NAME=github_analyzer
DB_CONNECTION_LIMIT=10

# GitHub API
# Optional but strongly recommended: without it you're limited to 60 requests/hour.
# With a token (no special scopes needed for public data): 5000 requests/hour.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# How many repos to scan per profile when computing stars/languages (max 100 per page)
GITHUB_REPO_SCAN_LIMIT=300

# Rate limiting (requests per window, per IP) for this API itself
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
